		"@sveltejs/vite-plugin-svelte": "^5.0.0",
		"@tsconfig/svelte": "^5.0.8",
		"@types/node": "^25.9.1",
		"@vitest/browser": "^4.1.8",
		"@vitest/browser-playwright": "^4.1.8",
		"eslint": "^10.4.1",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-perfectionist": "^5.9.0",
		"eslint-plugin-svelte": "^3.19.0",
		"playwright": "^1.60.0",
		"prettier": "^3.8.3",

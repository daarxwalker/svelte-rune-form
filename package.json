{
	"name": "svelte-rune-form",
	"version": "0.2.0",
	"description": "Lightweight, type-safe form library for Svelte 5 built with runes",
	"license": "MIT",
	"author": "Dominik Linduška",
	"repository": {
		"type": "git",
		"url": "https://github.com/daarxwalker/svelte-rune-form"
	},
	"keywords": [
		"svelte",
		"svelte5",
		"form",
		"runes",
		"valibot"
	],
	"type": "module",
	"exports": {
